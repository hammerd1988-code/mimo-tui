{
  "name": "@titenq/mimo-tui",
  "version": "1.0.2",
  "description": "Terminal UI for chatting with MiMo models through Xiaomi's OpenAI-compatible API",
  "main": "dist/index.js",
  "bin": {
    "mimo-tui": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt",
    "mimo-tui.png"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.tsx",
    "dev:watch": "tsx --watch src/index.tsx",
    "format": "npm run lint:fix && prettier --write .",
    "lint": "npm run format && oxlint && npm run type-check",
    "lint:fix": "oxlint --fix -c oxlintrc.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -p tsconfig.json --noEmit --incremental --skipLibCheck --tsBuildInfoFile .tsbuildinfo"
  },
  "keywords": [
    "mimo",
    "tui",
    "cli",
    "terminal",
    "ink",
    "typescript",
    "xiaomi",
    "openai-compatible"
  ],
  "author": "TitenQ<titenq@gmail.com>",
  "homepage": "https://github.com/titenq/mimo-tui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/titenq/mimo-tui.git"
  },
  "bugs": {
    "url": "https://github.com/titenq/mimo-tui/issues"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.1.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.0",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "clipboardy": "^5.3.1",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.5",
    "react": "^19.2.4"
  }
}
